#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  cc-use delegate "TASK" [--project DIR] [--session NAME] [--replace]
  cc-use monitor [--project DIR]
  cc-use project-status [--project DIR] [--json]
  cc-use snapshot SESSION
  cc-use kill SESSION
  cc-use list
EOF
}

die() {
  echo "cc-use: $*" >&2
  exit 1
}

json_escape() {
  tr '\n\r\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

safe_name() {
  printf '%s' "$1" | tr -c '[:alnum:]_-' '-'
}

now_epoch() {
  date +%s
}

project_abs() {
  (cd "$1" && pwd)
}

cc_dir() {
  printf '%s/.cc-use' "$1"
}

state_dir() {
  printf '%s/state' "$(cc_dir "$1")"
}

session_name_for_project() {
  local project_dir="$1"
  printf 'cc-use-%s' "$(safe_name "$(basename "$project_dir")")"
}

hash_text() {
  if command -v openssl >/dev/null 2>&1; then
    openssl dgst -sha256 -r | awk '{print $1}'
  elif command -v sha256sum >/dev/null 2>&1; then
    sha256sum | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    LC_ALL=C LANG=C shasum -a 256 | awk '{print $1}'
  else
    cksum | awk '{print $1}'
  fi
}

normalize_screen() {
  sed -E $'s/\x1b\\[[0-?]*[ -\\/]*[@-~]//g; s/[[:space:]]+$//'
}

tmux_has_session() {
  tmux has-session -t "$1" >/dev/null 2>&1
}

tmux_capture() {
  tmux capture-pane -t "$1" -p 2>/dev/null | normalize_screen
}

tmux_send_text() {
  local session="$1"
  local text="$2"
  local tmp
  local buffer
  tmp="$(mktemp)"
  buffer="cc-use-send-$$"
  printf '%s' "$text" > "$tmp"
  tmux send-keys -t "$session" C-u
  tmux load-buffer -b "$buffer" "$tmp"
  tmux paste-buffer -d -b "$buffer" -t "$session"
  rm -f "$tmp"
  sleep 0.5
  tmux send-keys -t "$session" Enter
  sleep 0.7
  tmux send-keys -t "$session" C-m
  sleep 0.7
  tmux send-keys -t "$session" Enter
}

build_inner_task_prompt() {
  local task="$1"
  task="$(printf '%s' "$task" | tr '\n' ' ')"
  printf '%s' "You are the inner coding agent for cc-use. Do the requested implementation work directly in the current project directory. Do not invoke cc-use, do not start another coding agent, and do not ask the user to run commands. Use your own tools to inspect, edit, and test the project. Task: $task"
}

build_cc_command() {
  local profile="$1"
  local sandbox="$2"
  local approval="$3"
  local codex_bin
  codex_bin="$(resolve_codex_binary)"
  # Current implementation uses Codex CLI as the default inner CC.
  printf 'env -u CODEX_MANAGED_BY_NPM -u CODEX_THREAD_ID -u CODEX_CI %q --profile %q --no-alt-screen --ask-for-approval %q --sandbox %q' "$codex_bin" "$profile" "$approval" "$sandbox"
}

resolve_codex_binary() {
  local codex_path
  local prefix
  local package_root
  local native
  codex_path="$(command -v codex 2>/dev/null || true)"
  [ -n "$codex_path" ] || die "codex command not found"

  # npm global layout: <prefix>/bin/codex -> <prefix>/lib/node_modules/@openai/codex/bin/codex.js
  prefix="$(cd "$(dirname "$codex_path")/.." && pwd)"
  package_root="$prefix/lib/node_modules/@openai/codex"
  if [ -d "$package_root" ]; then
    native="$(find "$package_root" -path '*/vendor/*/codex/codex' -type f -perm -111 2>/dev/null | head -1)"
    if [ -n "$native" ]; then
      printf '%s' "$native"
      return
    fi
  fi

  printf '%s' "$codex_path"
}

save_session_info() {
  local project_dir="$1"
  local session="$2"
  local agent="$3"
  local profile="$4"
  local sandbox="$5"
  local approval="$6"
  local state
  state="$(state_dir "$project_dir")"
  mkdir -p "$state"

  cat > "$state/session-info.env" <<EOF
project_dir=$(printf '%q' "$project_dir")
session=$(printf '%q' "$session")
agent=$(printf '%q' "$agent")
profile=$(printf '%q' "$profile")
sandbox=$(printf '%q' "$sandbox")
approval=$(printf '%q' "$approval")
EOF

  cat > "$state/session-info.json" <<EOF
{
  "agent": "$(printf '%s' "$agent" | json_escape)",
  "approval": "$(printf '%s' "$approval" | json_escape)",
  "profile": "$(printf '%s' "$profile" | json_escape)",
  "project_dir": "$(printf '%s' "$project_dir" | json_escape)",
  "sandbox": "$(printf '%s' "$sandbox" | json_escape)",
  "session": "$(printf '%s' "$session" | json_escape)"
}
EOF
}

load_session_info() {
  local target_project="$1"
  local env_file
  env_file="$(state_dir "$target_project")/session-info.env"
  [ -f "$env_file" ] || die "missing session state: $env_file"
  # shellcheck disable=SC1090
  source "$env_file"
}

write_watch_state() {
  local project_dir="$1"
  local session="$2"
  local digest="$3"
  local silence_started="$4"
  local next_check="$5"
  local observations="$6"
  local last_observation_json="${7:-null}"
  local state
  state="$(state_dir "$project_dir")"
  mkdir -p "$state"
  cat > "$state/watch.env" <<EOF
last_digest=$(printf '%q' "$digest")
silence_started_at=$silence_started
next_check_at=$next_check
observation_count=$observations
EOF
  cat > "$state/watch.json" <<EOF
{
  "last_digest": "$(printf '%s' "$digest" | json_escape)",
  "next_check_at": $next_check,
  "observation_count": $observations,
  "session": "$(printf '%s' "$session" | json_escape)",
  "silence_started_at": $silence_started,
  "last_observation": $last_observation_json
}
EOF
}

load_watch_state() {
  local project_dir="$1"
  local env_file
  env_file="$(state_dir "$project_dir")/watch.env"
  if [ -f "$env_file" ]; then
    # shellcheck disable=SC1090
    source "$env_file"
  else
    last_digest=""
    silence_started_at=0
    next_check_at=0
    observation_count=0
  fi
}

decision_for_screen() {
  local screen_file="$1"
  local silence="$2"
  local lower
  lower="$(tr '[:upper:]' '[:lower:]' < "$screen_file")"
  if printf '%s' "$lower" | grep -Eq 'permission|approve|allow|continue\?|password'; then
    decision_action="intervene"
    decision_next=15
    decision_confidence="0.72"
    decision_reason="The terminal may be waiting for explicit user input."
  elif printf '%s' "$lower" | grep -Eq 'pytest|npm test|pnpm test|yarn test|cargo test|go test|running (tests?|command|suite|migration|server)'; then
    decision_action="wait"
    if [ "$silence" -lt 180 ]; then decision_next=120; else decision_next=60; fi
    decision_confidence="0.66"
    decision_reason="The terminal looks like it may be running a command that can stay quiet for a while."
  elif printf '%s' "$lower" | grep -Eq 'npm (install|ci|run build)|pnpm (install|run build)|yarn (install|build)|pip install|uv sync|building|compiling|bundling|installing|downloading'; then
    decision_action="wait"
    decision_next=180
    decision_confidence="0.64"
    decision_reason="The terminal looks like it may be doing long-running setup or build work."
  else
    decision_action="wait"
    decision_next=60
    decision_confidence="0.5"
    decision_reason="No screen changes were observed; wait a moderate interval before checking again."
  fi
}

watch_once() {
  local project_dir="$1"
  local session="$2"
  local initial_quiet="$3"
  local poll_interval="$4"
  local max_observations="$5"
  local state
  local screens
  local history
  local curr
  local digest
  local now
  local sleep_for
  local observation_json
  state="$(state_dir "$project_dir")"
  screens="$state/screens"
  history="$state/watch.observations.jsonl"
  mkdir -p "$state" "$screens"

  load_watch_state "$project_dir"

  while :; do
    now="$(now_epoch)"
    curr="$(mktemp)"
    if ! tmux_capture "$session" > "$curr"; then
      observation_json="{\"event\":\"session_unavailable\",\"session\":\"$(printf '%s' "$session" | json_escape)\",\"observed_at\":$now}"
      printf '%s\n' "$observation_json"
      printf '%s\n' "$observation_json" >> "$history"
      rm -f "$curr"
      return 0
    fi
    digest="$(hash_text < "$curr")"

    if [ "$digest" != "${last_digest:-}" ]; then
      silence_started_at="$now"
      next_check_at=$((now + initial_quiet))
      write_watch_state "$project_dir" "$session" "$digest" "$silence_started_at" "$next_check_at" "${observation_count:-0}" "null"
      last_digest="$digest"
      rm -f "$curr"
      sleep "$poll_interval"
      continue
    fi

    if [ "${next_check_at:-0}" -le 0 ]; then
      next_check_at=$((now + initial_quiet))
      write_watch_state "$project_dir" "$session" "$digest" "${silence_started_at:-$now}" "$next_check_at" "${observation_count:-0}" "null"
    fi

    if [ "$now" -ge "$next_check_at" ]; then
      local silence
      local screen_path
      silence=$((now - silence_started_at))
      observation_count=$((observation_count + 1))
      screen_path="$screens/$(safe_name "$session")-$(printf '%04d' "$observation_count").txt"
      cp "$curr" "$screen_path"
      decision_for_screen "$curr" "$silence"
      observation_json="{\"event\":\"observation\",\"session\":\"$(printf '%s' "$session" | json_escape)\",\"observed_at\":$now,\"silence_seconds\":$silence,\"screen_digest\":\"$digest\",\"screen_path\":\"$(printf '%s' "$screen_path" | json_escape)\",\"decision\":{\"action\":\"$decision_action\",\"next_check_after_seconds\":$decision_next,\"reason\":\"$(printf '%s' "$decision_reason" | json_escape)\",\"confidence\":$decision_confidence}}"
      next_check_at=$((now + decision_next))
      write_watch_state "$project_dir" "$session" "$digest" "$silence_started_at" "$next_check_at" "$observation_count" "$observation_json"
      printf '%s\n' "$observation_json"
      printf '%s\n' "$observation_json" >> "$history"
      rm -f "$curr"
      [ "$max_observations" -le 0 ] || [ "$observation_count" -ge "$max_observations" ] && return 0
    else
      rm -f "$curr"
    fi

    now="$(now_epoch)"
    sleep_for="$poll_interval"
    if [ "$next_check_at" -gt "$now" ] && [ $((next_check_at - now)) -lt "$sleep_for" ]; then
      sleep_for=$((next_check_at - now))
      [ "$sleep_for" -le 0 ] && sleep_for=1
    fi
    sleep "$sleep_for"
  done
}

cmd_delegate() {
  local task="$1"; shift
  local project="."
  local session=""
  local profile="zilliz"
  local sandbox="workspace-write"
  local approval="never"
  local replace=false
  local initial_quiet=30
  local poll_interval=2
  local max_observations=1
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --session) session="$2"; shift 2 ;;
      --profile) profile="$2"; shift 2 ;;
      --sandbox) sandbox="$2"; shift 2 ;;
      --approval) approval="$2"; shift 2 ;;
      --replace) replace=true; shift ;;
      --initial-quiet-seconds) initial_quiet="$2"; shift 2 ;;
      --poll-interval) poll_interval="$2"; shift 2 ;;
      --max-observations) max_observations="$2"; shift 2 ;;
      *) die "unknown delegate option: $1" ;;
    esac
  done
  project="$(project_abs "$project")"
  [ -n "$session" ] || session="$(session_name_for_project "$project")"
  save_session_info "$project" "$session" "cc" "$profile" "$sandbox" "$approval"

  if $replace && tmux_has_session "$session"; then
    tmux kill-session -t "$session" >/dev/null 2>&1 || true
  fi

  if ! tmux_has_session "$session"; then
    local command
    local keepalive
    local env_args=()
    local env_line
    local env_key
    command="$(build_cc_command "$profile" "$sandbox" "$approval")"
    while IFS= read -r env_line; do
      env_key="${env_line%%=*}"
      case "$env_key" in
        ''|*[!A-Za-z0-9_]*|[0-9]*)
          continue
          ;;
      esac
      env_args+=("-e" "$env_line")
    done < <(env)
    keepalive="$command; status=\$?; echo; echo cc-use inner exited:\$status; sleep 3600"
    tmux new-session -d -s "$session" "${env_args[@]}" -c "$project" "bash -c $(printf '%q' "$keepalive")"
    echo "launched $session: $command"
    sleep 5
    tmux send-keys -t "$session" Enter
    sleep 1
  fi

  tmux_send_text "$session" "$(build_inner_task_prompt "$task")"
  watch_once "$project" "$session" "$initial_quiet" "$poll_interval" "$max_observations"
}

cmd_monitor() {
  local project="."
  local initial_quiet=30
  local poll_interval=2
  local max_observations=1
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --initial-quiet-seconds) initial_quiet="$2"; shift 2 ;;
      --poll-interval) poll_interval="$2"; shift 2 ;;
      --max-observations) max_observations="$2"; shift 2 ;;
      *) die "unknown monitor option: $1" ;;
    esac
  done
  project="$(project_abs "$project")"
  load_session_info "$project"
  watch_once "$project" "$session" "$initial_quiet" "$poll_interval" "$max_observations"
}

cmd_project_status() {
  local project="."
  local as_json=false
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --json) as_json=true; shift ;;
      *) die "unknown project-status option: $1" ;;
    esac
  done
  project="$(project_abs "$project")"
  load_session_info "$project"
  local loaded_project_dir="$project_dir"
  load_watch_state "$project"
  local now silence remaining
  now="$(now_epoch)"
  silence=$((now - ${silence_started_at:-now}))
  remaining=$((next_check_at - now))
  [ "$remaining" -lt 0 ] && remaining=0
  if $as_json; then
    cat <<EOF
{"config":{"project_dir":"$(printf '%s' "$loaded_project_dir" | json_escape)","session":"$(printf '%s' "$session" | json_escape)","agent":"$(printf '%s' "$agent" | json_escape)","profile":"$(printf '%s' "$profile" | json_escape)","sandbox":"$(printf '%s' "$sandbox" | json_escape)","approval":"$(printf '%s' "$approval" | json_escape)"},"watch":{"observation_count":${observation_count:-0},"silence_seconds":$silence,"seconds_until_next_check":$remaining}}
EOF
  else
    echo "project: $loaded_project_dir"
    echo "session: $session"
    echo "agent: $agent"
    echo "observations: ${observation_count:-0}"
    echo "silence_seconds: $silence"
    echo "seconds_until_next_check: $remaining"
  fi
}

cmd="${1:-}"
[ -n "$cmd" ] || { usage; exit 1; }
shift || true

case "$cmd" in
  delegate)
    [ "$#" -ge 1 ] || die "delegate requires TASK"
    task="$1"; shift
    cmd_delegate "$task" "$@"
    ;;
  monitor)
    cmd_monitor "$@"
    ;;
  project-status)
    cmd_project_status "$@"
    ;;
  snapshot)
    [ "$#" -eq 1 ] || die "snapshot requires SESSION"
    tmux_capture "$1"
    ;;
  kill)
    [ "$#" -eq 1 ] || die "kill requires SESSION"
    tmux kill-session -t "$1" >/dev/null 2>&1 || true
    ;;
  list)
    tmux list-sessions -F "#{session_name}" 2>/dev/null || true
    ;;
  *)
    usage
    exit 1
    ;;
esac
