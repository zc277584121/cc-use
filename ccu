#!/usr/bin/env bash
# ccu — launch cc-use supervisor from any project directory
# Install: curl -fsSL https://raw.githubusercontent.com/zc277584121/cc-use/main/ccu -o ~/.local/bin/ccu && chmod +x ~/.local/bin/ccu
# Usage:  ccu                    # interactive mode
#         ccu "Fix the auth bug" # with initial task

set -e

# --- Pre-flight checks ---

if ! command -v claude &>/dev/null; then
  echo "Error: 'claude' (Claude Code CLI) is not installed."
  echo "Install: https://docs.anthropic.com/en/docs/claude-code"
  exit 1
fi

if ! command -v tmux &>/dev/null; then
  echo "Error: 'tmux' is not installed."
  echo "Install: sudo apt install tmux  (or brew install tmux)"
  exit 1
fi

# --- Setup ---

mkdir -p .cc-use/state

# Auto-trigger cc-use skill via CLAUDE.md in .cc-use/
if [ ! -f .cc-use/CLAUDE.md ]; then
  cat > .cc-use/CLAUDE.md <<'CLAUDEMD'
You are the **outer Claude** (supervisor) in a cc-use session.

Use the cc-use skill for ALL tasks. Your job is to:
1. Launch an inner Claude in tmux to do the implementation work
2. Monitor progress via screen-diff
3. Steer and correct as needed
4. Run end-to-end acceptance tests
5. Report results to the user

The user's project is in the parent directory (`../`). Do NOT read source code or edit files directly — delegate everything to the inner Claude.
CLAUDEMD
fi

cd .cc-use

# --- Launch ---

if [ $# -gt 0 ]; then
  exec claude "$*"
else
  exec claude
fi
